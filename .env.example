# ── Django ─────────────────────────────────────────────
# Generate a fresh key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-50-random-chars

# Local dev: True. Production: False (or unset).
DEBUG=True

# Comma-separated list, no spaces. In production set to your Railway domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ─────────────────────────────────────────
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432

# ── Optional: RapidAPI for circuit enrichment ─────────
# Only needed if you re-run the legacy seed_db.py / utils.py enrichment paths.
RAPIDAPI_KEY=
